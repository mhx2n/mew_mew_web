{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "permissions": { "type": "array", "items": { "type": "string" } },
        "rollNumber": { "type": "string" },
        "enrolledCourses": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "QuizQuestion": {
      "title": "QuizQuestion",
      "description": "A generated quiz question",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctOptionIndex": { "type": "number" },
        "explanation": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "sending", "sent", "error"] },
        "image": { "type": "string" },
        "topic": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "question", "options", "correctOptionIndex", "explanation", "status"]
    },
    "TelegramSettings": {
      "title": "TelegramSettings",
      "description": "User's telegram settings",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "botToken": { "type": "string" },
        "chatId": { "type": "string" },
        "channels": { "type": "array" },
        "activeChannelId": { "type": "string" },
        "selectedChannelIds": { "type": "array" },
        "questionPrefix": { "type": "string" },
        "explanationSuffix": { "type": "string" },
        "prefixes": { "type": "array" },
        "suffixes": { "type": "array" },
        "activePrefixId": { "type": "string" },
        "activeSuffixId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "quizzes/{quizId}": {
      "schema": { "$ref": "#/entities/QuizQuestion" },
      "description": "Quiz questions generated by users"
    },
    "settings/{userId}": {
      "schema": { "$ref": "#/entities/TelegramSettings" },
      "description": "User-specific settings"
    }
  }
}
